#!/usr/bin/env bash
set -euo pipefail

TP_PREFIX="tb-"
TP_DIR="/etc/tetragon/tetragon.tp.d"
TETRA_BIN="${TETRA_BIN:-tetra}"

log() { echo "[clean-stop] $*"; }
warn() { echo "[clean-stop] WARN: $*" >&2; }

need_root() {
  if [[ "$(id -u)" -ne 0 ]]; then
    echo "[clean-stop] ERROR: must run as root (try: sudo ./clean-stop)" >&2
    exit 1
  fi
}

delete_yaml_files() {
  if [[ -d "$TP_DIR" ]]; then
    log "deleting YAML files: ${TP_DIR}/${TP_PREFIX}*.yaml"
    rm -f "${TP_DIR}/${TP_PREFIX}"*.yaml 2>/dev/null || true
  else
    warn "dir not found: $TP_DIR"
  fi
}

list_tp_policies() {
  # Parse "tetra tracingpolicy list" output:
  # ID NAME STATE ...
  # 1  foo  enabled ...
  "$TETRA_BIN" tracingpolicy list 2>/dev/null \
    | awk -v pfx="$TP_PREFIX" '
        NR==1 {next}
        $1 ~ /^[0-9]+$/ && $2 ~ ("^" pfx) {print $2}
      '
}

delete_tp_policies() {
  local names
  names="$(list_tp_policies || true)"
  if [[ -z "${names}" ]]; then
    log "no tracingpolicies with prefix '${TP_PREFIX}' found"
    return 0
  fi

  log "deleting tracingpolicies with prefix '${TP_PREFIX}' one-by-one"
  while IFS= read -r name; do
    [[ -n "$name" ]] || continue
    log "delete tracingpolicy: $name"
    # Must delete one-by-one; no wildcard support.
    if ! "$TETRA_BIN" tracingpolicy delete "$name" >/dev/null 2>&1; then
      # Try alternate subcommand forms (some installs support these).
      "$TETRA_BIN" tracingpolicy del "$name" >/dev/null 2>&1 || true
      "$TETRA_BIN" tp delete "$name" >/dev/null 2>&1 || true
      "$TETRA_BIN" tp del "$name" >/dev/null 2>&1 || true
    fi
  done <<< "$names"
}

stop_services() {
  log "stopping services"
  systemctl stop tetrablocker >/dev/null 2>&1 || true
  #systemctl stop tetragon-enterprise >/dev/null 2>&1 || true
  log "done"
}

main() {
  need_root

  # Quick sanity check that tetra exists
  if ! command -v "$TETRA_BIN" >/dev/null 2>&1; then
    echo "[clean-stop] ERROR: tetra binary not found: $TETRA_BIN" >&2
    exit 1
  fi

  delete_yaml_files
  delete_tp_policies
  stop_services

  log "status (best-effort)"
  systemctl status tetrablocker --no-pager >/dev/null 2>&1 && systemctl status tetrablocker --no-pager || true
  systemctl status tetragon-enterprise --no-pager >/dev/null 2>&1 && systemctl status tetragon-enterprise --no-pager || true
}

main "$@"


# -----------------------------
# Common helpers
# -----------------------------

def now() -> float:
    return time.time()

def sha256_hex(data: bytes) -> str:
    return hashlib.sha256(data).hexdigest()

def json_dumps_stable(obj: dict) -> str:
    return json.dumps(obj, sort_keys=True, separators=(",", ":"), ensure_ascii=True)

def sha256_json(obj: dict) -> str:
    return sha256_hex(json_dumps_stable(obj).encode("utf-8"))

def norm_domain(s: str) -> str:
    s = (s or "").strip().lower()
    if not s:
        return ""
    return s if s.endswith(".") else (s + ".")

def valid_ip(ip: str) -> bool:
    ip = (ip or "").strip()
    if not ip:
        return False
    if ":" in ip:
        return bool(re.match(r"^[0-9a-fA-F:]+$", ip))
    return bool(re.match(r"^\d{1,3}(\.\d{1,3}){3}$", ip))

def is_ipv6(ip: str) -> bool:
    return ":" in ip

def ip_to_cidr(ip: str) -> str:
    ip = ip.strip()
    if "/" in ip:
        return ip
    return f"{ip}/128" if is_ipv6(ip) else f"{ip}/32"

def atomic_write(path: str, content: str, mode: int = 0o644) -> None:
    d = os.path.dirname(path)
    os.makedirs(d, exist_ok=True)
    tmp = os.path.join(d, f".{os.path.basename(path)}.tmp.{os.getpid()}")
    with open(tmp, "w", encoding="utf-8") as f:
        f.write(content)
        f.flush()
        os.fsync(f.fileno())
    os.chmod(tmp, mode)
    os.replace(tmp, path)

def atomic_write_json(path: str, obj: dict, mode: int = 0o644) -> None:
    atomic_write(path, json.dumps(obj, indent=2, sort_keys=True, ensure_ascii=True) + "\n", mode=mode)

def safe_unlink(path: str) -> None:
    try:
        os.unlink(path)
    except FileNotFoundError:
        return

def run_cmd(cmd: List[str], timeout: int = 30) -> Tuple[int, str, str]:
    p = subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
    try:
        out, err = p.communicate(timeout=timeout)
    except subprocess.TimeoutExpired:
        p.kill()
        out, err = p.communicate()
        return 124, out, err
    return p.returncode, out, err


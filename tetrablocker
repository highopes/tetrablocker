class TetraBlocker:
    def __init__(self, cfg_path: str):
        self.cfg_path = cfg_path
        self.cfg = load_config(cfg_path)
        ensure_dirs(self.cfg)

        self.trusted_binaries: Set[str] = set(self.cfg.allowlist_trusted_binaries or [])

        self.cfg_mtime = 0.0
        self.last_cfg_reload = 0.0

        self.rule_states: Dict[str, RuleState] = {}
        self.last_dns_dump_ts = 0.0
        self.last_dns_dump_text = ""
        self.pending_rule_apply: Set[str] = set()

        self.allowlist_mtime = 0.0
        self.last_allowlist_reload = 0.0
        self.allowlist_obj: dict = {}
        self.allowlist_items: Dict[Tuple[str, str, str, int], ALItem] = {}
        self.allowlist_learning_started_at: float = 0.0
        self.allowlist_learning_completed: bool = False
        self.allowlist_dirty: bool = False
        self.allowlist_last_flush: float = 0.0

        self.domain_ip_cache: Dict[str, Dict[str, float]] = {}
        self.domain_last_refresh: float = 0.0

        self.allowlist_policy_state_path = os.path.join(self.cfg.state_dir, "allowlist_policies.json")
        self.allowlist_policy_state: Dict[str, str] = {}
        self.pending_allowlist_reconcile: bool = True

        self.stop = False

        self._load_rule_states()
        self._load_allowlist_policy_state()
        self._load_or_init_allowlist(force_init=True)

        if self.cfg.prewarm_on_start:
            for r in self.cfg.rules:
                for d in r.norm_domains():
                    prewarm_domain(d)
                self.pending_rule_apply.add(r.name)

    def handle_signal(self, signum, frame):
        self.stop = True

    def throttled_dns_dump(self) -> str:
        t = now()
        min_iv = max(0, int(self.cfg.dns_dump_min_interval_seconds))
        if min_iv == 0:
            self.last_dns_dump_text = dns_dump(self.cfg)
            self.last_dns_dump_ts = t
            return self.last_dns_dump_text
        if t - self.last_dns_dump_ts < min_iv and self.last_dns_dump_text:
            return self.last_dns_dump_text
        self.last_dns_dump_text = dns_dump(self.cfg)
        self.last_dns_dump_ts = t
        return self.last_dns_dump_text

    def _rule_state_path(self, name: str) -> str:
        return os.path.join(self.cfg.state_dir, f"{name}.json")

    def _load_rule_states(self) -> None:
        self.rule_states = {}
        try:
            for fn in os.listdir(self.cfg.state_dir):
                if not fn.endswith(".json"):
                    continue
                if fn == "allowlist_policies.json":
                    continue
                path = os.path.join(self.cfg.state_dir, fn)
                try:
                    with open(path, "r", encoding="utf-8") as f:
                        obj = json.load(f)
                    if not obj.get("name"):
                        continue
                    st = RuleState(
                        name=str(obj["name"]),
                        spec_hash=str(obj.get("spec_hash", "")),
                        last_apply_ts=float(obj.get("last_apply_ts", 0.0)),
                        last_yaml_hash=str(obj.get("last_yaml_hash", "")),
                        ip_cache={str(k): float(v) for k, v in (obj.get("ip_cache", {}) or {}).items()},
                    )
                    self.rule_states[st.name] = st
                except Exception:
                    continue
        except FileNotFoundError:
            pass

    def _save_rule_state(self, st: RuleState) -> None:
        obj = {
            "name": st.name,
            "spec_hash": st.spec_hash,
            "last_apply_ts": st.last_apply_ts,
            "last_yaml_hash": st.last_yaml_hash,
            "ip_cache": st.ip_cache,
        }
        atomic_write_json(self._rule_state_path(st.name), obj, mode=0o600)

    def _load_allowlist_policy_state(self) -> None:
        self.allowlist_policy_state = {}
        try:
            with open(self.allowlist_policy_state_path, "r", encoding="utf-8") as f:
                obj = json.load(f)
            if isinstance(obj, dict):
                for k, v in obj.items():
                    self.allowlist_policy_state[str(k)] = str(v)
        except FileNotFoundError:
            pass
        except Exception:
            pass

    def _save_allowlist_policy_state(self) -> None:
        atomic_write_json(self.allowlist_policy_state_path, self.allowlist_policy_state, mode=0o600)

    def _load_or_init_allowlist(self, force_init: bool) -> None:
        path = self.cfg.allowlist_file
        if not os.path.exists(path):
            self.allowlist_obj = self._default_allowlist()
            atomic_write_json(path, self.allowlist_obj, mode=0o644)
            self.allowlist_mtime = os.stat(path).st_mtime
        else:
            self._reload_allowlist_if_changed(force=force_init)

        self._materialize_allowlist_items()
        self._ensure_trusted_seed_items()
        self._materialize_allowlist_items()
        self.pending_allowlist_reconcile = True

    def _default_allowlist(self) -> dict:
        t = now()
        seed_bins = [
            "/usr/lib/systemd/systemd-resolved",
            "/lib/systemd/systemd-resolved",
        ]
        items = []
        for b in seed_bins:
            items.append({
                "binary": b,
                "binary_operator": "In",
                "proto": "udp",
                "port": 53,
                "domains": ["*"],
                "cidrs": [],
                "updated_at": t,
            })
            items.append({
                "binary": b,
                "binary_operator": "In",
                "proto": "tcp",
                "port": 53,
                "domains": ["*"],
                "cidrs": [],
                "updated_at": t,
            })
        return {
            "version": 1,
            "learning": {
                "duration_seconds": int(self.cfg.allowlist_learning_seconds),
                "started_at": 0.0,
                "completed": False,
                "completed_at": 0.0
            },
            "items": items,
        }

    def _reload_allowlist_if_changed(self, force: bool) -> None:
        t = now()
        if not force and (t - self.last_allowlist_reload) < max(1, int(self.cfg.allowlist_reload_seconds)):
            return
        self.last_allowlist_reload = t

        path = self.cfg.allowlist_file
        try:
            st = os.stat(path)
        except FileNotFoundError:
            return

        if not force and st.st_mtime <= self.allowlist_mtime:
            return

        with open(path, "r", encoding="utf-8") as f:
            obj = json.load(f)

        if not isinstance(obj, dict):
            return

        self.allowlist_obj = obj
        self.allowlist_mtime = st.st_mtime
        self._materialize_allowlist_items()
        self._ensure_trusted_seed_items()
        self._materialize_allowlist_items()
        self.pending_allowlist_reconcile = True

    def _materialize_allowlist_items(self) -> None:
        obj = self.allowlist_obj or {}
        learning = obj.get("learning", {}) or {}
        self.allowlist_learning_started_at = float(learning.get("started_at", 0.0) or 0.0)
        self.allowlist_learning_completed = bool(learning.get("completed", False))

        items: Dict[Tuple[str, str, str, int], ALItem] = {}
        for it in (obj.get("items", []) or []):
            try:
                binary = str(it.get("binary", "")).strip()
                bop = str(it.get("binary_operator", "In")).strip() or "In"
                proto = str(it.get("proto", "")).strip().lower()
                port = int(it.get("port", 0))
                doms = [norm_domain(x) if x != "*" else "*" for x in (it.get("domains", []) or [])]
                doms = [d for d in doms if d]
                cidrs = [str(x).strip() for x in (it.get("cidrs", []) or []) if str(x).strip()]
                upd = float(it.get("updated_at", 0.0) or 0.0)
                if not binary or proto not in ("tcp", "udp") or port <= 0:
                    continue
                item = ALItem(
                    binary=binary,
                    binary_operator=bop,
                    proto=proto,
                    port=port,
                    domains=sorted(set(doms)),
                    cidrs=sorted(set(cidrs)),
                    updated_at=upd,
                )
                items[item.key()] = item
            except Exception:
                continue
        self.allowlist_items = items

    def _rebuild_allowlist_obj_items_from_items(self) -> None:
        self.allowlist_obj["items"] = []
        for k in sorted(self.allowlist_items.keys()):
            it = self.allowlist_items[k]
            self.allowlist_obj["items"].append({
                "binary": it.binary,
                "binary_operator": it.binary_operator,
                "proto": it.proto,
                "port": int(it.port),
                "domains": it.domains,
                "cidrs": it.cidrs,
                "updated_at": float(it.updated_at),
            })
        self.allowlist_dirty = True

    def _ensure_trusted_seed_items(self) -> None:
        if "items" not in self.allowlist_obj or not isinstance(self.allowlist_obj.get("items"), list):
            self.allowlist_obj["items"] = []
        changed = False
        t = now()

        for b in sorted(self.trusted_binaries):
            if not b:
                continue
            base = os.path.basename(b)
            if base != "systemd-resolved":
                continue

            for proto in ("udp", "tcp"):
                key = ("In", b, proto, 53)
                if key not in self.allowlist_items:
                    self.allowlist_items[key] = ALItem(
                        binary=b,
                        binary_operator="In",
                        proto=proto,
                        port=53,
                        domains=["*"],
                        cidrs=[],
                        updated_at=t,
                    )
                    changed = True

        if changed:
            self._rebuild_allowlist_obj_items_from_items()

    def _flush_allowlist_if_needed(self) -> None:
        if not self.allowlist_dirty:
            return
        if now() - self.allowlist_last_flush < 1.0:
            return
        self.allowlist_last_flush = now()
        self.allowlist_dirty = False
        atomic_write_json(self.cfg.allowlist_file, self.allowlist_obj, mode=0o644)
        self.allowlist_mtime = os.stat(self.cfg.allowlist_file).st_mtime

    def _set_learning_flag(self, started_at: float, completed: bool) -> None:
        if "learning" not in self.allowlist_obj:
            self.allowlist_obj["learning"] = {}
        self.allowlist_obj["learning"]["duration_seconds"] = int(self.cfg.allowlist_learning_seconds)
        self.allowlist_obj["learning"]["started_at"] = float(started_at)
        self.allowlist_obj["learning"]["completed"] = bool(completed)
        self.allowlist_obj["learning"]["completed_at"] = float(now() if completed else 0.0)
        self.allowlist_dirty = True
        self._materialize_allowlist_items()

    def _learning_mode(self) -> bool:
        if not self.cfg.allowlist:
            return False
        if self.allowlist_learning_completed:
            return False
        if self.allowlist_learning_started_at <= 0.0:
            self._set_learning_flag(started_at=now(), completed=False)
        return True

    def _maybe_finish_learning(self) -> None:
        if not self.cfg.allowlist:
            return
        if self.allowlist_learning_completed:
            return
        if self.allowlist_learning_started_at <= 0.0:
            return
        if now() - self.allowlist_learning_started_at >= float(self.cfg.allowlist_learning_seconds):
            self._set_learning_flag(started_at=self.allowlist_learning_started_at, completed=True)
            self.pending_allowlist_reconcile = True

    def _allowlist_add_observation(self, binary: str, proto: str, port: int, domains: List[str], dest_ip: str) -> None:
        if not binary or proto not in ("tcp", "udp") or port <= 0:
            return

        bop = "In"
        bval = binary

        doms_norm: Set[str] = set()
        for d in domains:
            if d == "*":
                doms_norm.add("*")
            else:
                nd = norm_domain(d)
                if nd:
                    doms_norm.add(nd)

        cidrs_norm: Set[str] = set()
        if valid_ip(dest_ip):
            cidrs_norm.add(ip_to_cidr(dest_ip))

        key = (bop, bval, proto, int(port))
        item = self.allowlist_items.get(key)
        t = now()
        if item is None:
            item = ALItem(binary=bval, binary_operator=bop, proto=proto, port=int(port),
                          domains=sorted(doms_norm), cidrs=sorted(cidrs_norm), updated_at=t)
            self.allowlist_items[key] = item
        else:
            item.updated_at = t
            item.domains = sorted(set(item.domains) | doms_norm)
            item.cidrs = sorted(set(item.cidrs) | cidrs_norm)

        self._rebuild_allowlist_obj_items_from_items()

    def _refresh_domain_ips(self) -> None:
        if not self.cfg.allowlist:
            return
        if now() - self.domain_last_refresh < max(1, int(self.cfg.allowlist_domain_refresh_seconds)):
            return
        self.domain_last_refresh = now()

        domains: Set[str] = set()
        for it in self.allowlist_items.values():
            for d in it.domains:
                if d and d != "*":
                    domains.add(d)
        for d in sorted(domains):
            prewarm_domain(d)

        try:
            txt = self.throttled_dns_dump()
            pairs = parse_dns_dump(txt)
        except Exception:
            return

        t = now()
        for ip, dom in pairs:
            cidr = ip_to_cidr(ip)
            m = self.domain_ip_cache.setdefault(dom, {})
            m[cidr] = t

        ttl = 900.0
        max_ips = max(1, int(self.cfg.allowlist_domain_max_ips))
        for dom in list(self.domain_ip_cache.keys()):
            m = self.domain_ip_cache[dom]
            expire_before = t - ttl
            for cidr in list(m.keys()):
                if m[cidr] < expire_before:
                    del m[cidr]
            if len(m) > max_ips:
                items = sorted(m.items(), key=lambda kv: kv[1], reverse=True)[:max_ips]
                self.domain_ip_cache[dom] = dict(items)

    def _build_allow_groups(self, proto: str) -> Dict[Tuple[str, str], Dict[Tuple[Tuple[str, ...], Tuple[str, ...]], Set[int]]]:
        groups: Dict[Tuple[str, str], Dict[Tuple[Tuple[str, ...], Tuple[str, ...]], Set[int]]] = {}
        for it in self.allowlist_items.values():
            if it.proto != proto:
                continue
            bk = (it.binary_operator, it.binary)
            doms = tuple(sorted(set(it.domains)))
            cidrs = tuple(sorted(set(it.cidrs)))
            dk = (doms, cidrs)
            groups.setdefault(bk, {}).setdefault(dk, set()).add(int(it.port))
        return groups

    def _policy_name(self, suffix: str) -> str:
        return f"{self.cfg.allowlist_policy_prefix}-{suffix}"

    def _apply_policy_idempotent(self, policy_name: str, yaml: str) -> None:
        yaml_hash = sha256_hex(yaml.encode("utf-8"))
        path = os.path.join(self.cfg.policy_dir, f"{policy_name}.yaml")

        if self.allowlist_policy_state.get(policy_name) == yaml_hash and os.path.exists(path):
            return

        atomic_write(path, yaml, mode=0o644)
        tetra_delete_policy(self.cfg, policy_name)
        tetra_add_policy(self.cfg, path)

        self.allowlist_policy_state[policy_name] = yaml_hash
        self._save_allowlist_policy_state()

    def _cleanup_allowlist_policies(self) -> None:
        prefix = self.cfg.allowlist_policy_prefix + "-"
        for name in tetra_list_policies(self.cfg):
            if name.startswith(prefix):
                tetra_delete_policy(self.cfg, name)
                safe_unlink(os.path.join(self.cfg.policy_dir, f"{name}.yaml"))
                if name in self.allowlist_policy_state:
                    del self.allowlist_policy_state[name]
        self._save_allowlist_policy_state()

    def _reconcile_allowlist_policies(self) -> None:
        if not self.cfg.allowlist:
            self._cleanup_allowlist_policies()
            self.pending_allowlist_reconcile = False
            return

        if self._learning_mode():
            self._cleanup_allowlist_policies()
            self.pending_allowlist_reconcile = False
            return

        self._refresh_domain_ips()

        for proto, call in (("tcp", "tcp_connect"), ("udp", "udp_sendmsg")):
            groups = self._build_allow_groups(proto)

            exact_vals: List[str] = []
            prefix_vals: List[str] = []
            postfix_vals: List[str] = []

            for (bop, bval) in groups.keys():
                if bop == "In":
                    exact_vals.append(bval)
                elif bop == "Prefix":
                    prefix_vals.append(bval)
                elif bop == "Postfix":
                    postfix_vals.append(bval)

            match_blocks: List[Tuple[str, List[str]]] = []
            if exact_vals:
                match_blocks.append(("NotIn", sorted(set(exact_vals))))
            if prefix_vals:
                match_blocks.append(("NotPrefix", sorted(set(prefix_vals))))
            if postfix_vals:
                match_blocks.append(("NotPostfix", sorted(set(postfix_vals))))

            unknown_name = self._policy_name(f"unknown-{proto}")
            unknown_yaml = render_unknown_policy_yaml(
                name=unknown_name,
                call=call,
                match_blocks=match_blocks if match_blocks else [("NotIn", ["__none__"])],
                deny_action=self.cfg.allowlist_action,
                allow_dns_stub=bool(self.cfg.allowlist_global_dns_stub_allow),
                dns_stub_cidrs=self.cfg.allowlist_dns_stub_cidrs,
                dns_stub_ports=self.cfg.allowlist_dns_stub_ports,
            )
            self._apply_policy_idempotent(unknown_name, unknown_yaml)

            for (bop, bval), destmap in groups.items():
                allow_selectors_built: List[Tuple[List[str], List[List[str]]]] = []

                dest_items = []
                for (doms, cidrs), ports_set in destmap.items():
                    dest_items.append((doms, cidrs, sorted(ports_set)))
                dest_items.sort(key=lambda x: (",".join(x[0]), ",".join(x[1]), ",".join(map(str, x[2]))))

                max_allow_sel = max(1, int(self.cfg.allowlist_max_allow_selectors_per_policy))

                for doms, cidrs, ports in dest_items:
                    port_vals = compress_ports_to_values(ports, max_values=int(self.cfg.allowlist_port_values_per_selector))
                    allow_any_dest = ("*" in doms)

                    allow_cidrs: List[str] = []
                    if not allow_any_dest:
                        allow_cidrs.extend(list(cidrs))
                        for d in doms:
                            if d and d != "*":
                                m = self.domain_ip_cache.get(d, {})
                                allow_cidrs.extend(list(m.keys()))
                        allow_cidrs = sorted(set([c for c in allow_cidrs if c]))

                    if allow_any_dest:
                        allow_selectors_built.append((port_vals, []))
                    else:
                        av = max(1, int(self.cfg.allowlist_addr_values_per_selector))
                        chunks = chunk_list(allow_cidrs, av)
                        for ch in chunks:
                            if len(allow_selectors_built) >= max_allow_sel:
                                break
                            allow_selectors_built.append((port_vals, [ch]))

                    if len(allow_selectors_built) >= max_allow_sel:
                        break

                pol_name = self._policy_name(f"{proto}-{sha256_hex(f'{bop}:{bval}'.encode())[:10]}")

                deny_action: Optional[str] = self.cfg.allowlist_action
                if bop == "In" and bval in self.trusted_binaries:
                    deny_action = None

                yaml = render_allowlist_policy_yaml(
                    name=pol_name,
                    call=call,
                    bin_operator=bop,
                    bin_value=bval,
                    allow_selectors=allow_selectors_built,
                    deny_action=deny_action,
                )
                self._apply_policy_idempotent(pol_name, yaml)

        self.pending_allowlist_reconcile = False

    def _ensure_rule_state(self, rule: Rule) -> RuleState:
        st = self.rule_states.get(rule.name)
        if st is None:
            st = RuleState(name=rule.name)
            self.rule_states[rule.name] = st
        if not st.spec_hash:
            st.spec_hash = rule.spec_hash()
        return st

    def _refresh_rule_ips(self, rule: Rule, st: RuleState) -> None:
        domset = set(rule.norm_domains())
        attempts = max(1, int(self.cfg.dns_retry_attempts))
        sleep_s = max(0.0, float(self.cfg.dns_retry_sleep_seconds))

        for i in range(attempts):
            txt = self.throttled_dns_dump()
            pairs = parse_dns_dump(txt)

            t = now()
            for ip, dom in pairs:
                if dom in domset:
                    st.ip_cache[ip_to_cidr(ip)] = t

            expire_before = t - float(rule.ip_ttl_seconds)
            for cidr in list(st.ip_cache.keys()):
                if st.ip_cache[cidr] < expire_before:
                    del st.ip_cache[cidr]

            if len(st.ip_cache) > int(rule.max_ips):
                items = sorted(st.ip_cache.items(), key=lambda kv: kv[1], reverse=True)[: int(rule.max_ips)]
                st.ip_cache = dict(items)

            if st.ip_cache:
                return

            if i < attempts - 1:
                time.sleep(sleep_s)

    def apply_rule(self, rule: Rule, force: bool) -> None:
        st = self._ensure_rule_state(rule)
        if not force:
            cd = max(0, int(rule.apply_cooldown_seconds))
            if cd > 0 and (now() - st.last_apply_ts) < cd:
                return

        if not st.ip_cache:
            self._refresh_rule_ips(rule, st)

        cidrs = sorted(st.ip_cache.keys())
        if not cidrs:
            self._save_rule_state(st)
            return

        yaml = render_single_rule_yaml(rule, cidrs)
        yaml_hash = sha256_hex(yaml.encode("utf-8"))
        yaml_path = os.path.join(self.cfg.policy_dir, f"{rule.name}.yaml")

        if st.last_yaml_hash == yaml_hash and os.path.exists(yaml_path) and not force:
            st.last_apply_ts = now()
            self._save_rule_state(st)
            return

        atomic_write(yaml_path, yaml, mode=0o644)
        tetra_delete_policy(self.cfg, rule.name)
        tetra_add_policy(self.cfg, yaml_path)

        st.last_apply_ts = now()
        st.last_yaml_hash = yaml_hash
        st.spec_hash = rule.spec_hash()
        self._save_rule_state(st)

        print(f"policy applied name={rule.name} ips={len(cidrs)} path={yaml_path}", flush=True)

    def maybe_reload_config(self) -> None:
        t = now()
        if t - self.last_cfg_reload < max(1, int(self.cfg.config_reload_seconds)):
            return
        self.last_cfg_reload = t

        try:
            st = os.stat(self.cfg_path)
        except FileNotFoundError:
            return

        if st.st_mtime <= self.cfg_mtime:
            return

        old_allow = self.cfg.allowlist
        old_allow_file = self.cfg.allowlist_file
        old_prefix = self.cfg.allowlist_policy_prefix

        self.cfg = load_config(self.cfg_path)
        ensure_dirs(self.cfg)
        self.trusted_binaries = set(self.cfg.allowlist_trusted_binaries or [])
        self.cfg_mtime = st.st_mtime
        print(f"config reloaded mtime={self.cfg_mtime}", flush=True)

        if self.cfg.allowlist_file != old_allow_file:
            self.allowlist_mtime = 0.0
            self._load_or_init_allowlist(force_init=True)

        if self.cfg.allowlist_policy_prefix != old_prefix:
            self._cleanup_allowlist_policies()

        if old_allow and (not self.cfg.allowlist):
            self._cleanup_allowlist_policies()

        self.pending_allowlist_reconcile = True

    def _handle_process_connect_for_allowlist(self, ev: dict) -> None:
        pc = ev.get("process_connect")
        if not pc:
            return
        proc = pc.get("process", {}) or {}
        binary = str(proc.get("binary", "")).strip()
        proto = str(pc.get("protocol", "")).strip().lower()
        if proto == "tcp":
            p = "tcp"
        elif proto == "udp":
            p = "udp"
        else:
            return
        dest_ip = str(pc.get("destination_ip", "")).strip()
        try:
            port = int(pc.get("destination_port", 0))
        except Exception:
            port = 0

        names = pc.get("destination_names", []) or []
        doms: List[str] = []
        for n in names:
            if isinstance(n, str):
                nd = norm_domain(n)
                if nd:
                    doms.append(nd)

        if not doms and valid_ip(dest_ip):
            try:
                txt = self.throttled_dns_dump()
                pairs = parse_dns_dump(txt)
                for ip, dom in pairs:
                    if ip == dest_ip:
                        doms.append(dom)
                        break
            except Exception:
                pass

        if self._learning_mode():
            self._allowlist_add_observation(binary=binary, proto=p, port=port, domains=doms, dest_ip=dest_ip)

    def _handle_process_dns_for_allowlist(self, ev: dict) -> None:
        pd = ev.get("process_dns")
        if not pd:
            return
        proc = pd.get("process", {}) or {}
        dns = pd.get("dns", {}) or {}
        sock = pd.get("socket", {}) or {}
        if not dns.get("response", False):
            return
        if int(dns.get("return_code", 0)) != 0:
            return
        binary = str(proc.get("binary", "")).strip()
        names = dns.get("names", []) or []
        doms = []
        for n in names:
            if isinstance(n, str):
                dn = norm_domain(n)
                if dn:
                    doms.append(dn)
        dest_ip = str(sock.get("destination_ip", "")).strip()
        dest_port = int(sock.get("destination_port", 53) or 53)
        if self._learning_mode():
            self._allowlist_add_observation(binary=binary, proto="udp", port=dest_port, domains=doms, dest_ip=dest_ip)

    def run(self):
        signal.signal(signal.SIGINT, self.handle_signal)
        signal.signal(signal.SIGTERM, self.handle_signal)

        p = start_event_stream(self.cfg)
        print("event stream started", flush=True)

        while not self.stop:
            self.maybe_reload_config()
            self._reload_allowlist_if_changed(force=False)

            if self.cfg.allowlist:
                self._maybe_finish_learning()

            if not self.cfg.allowlist:
                if self.pending_allowlist_reconcile:
                    self._cleanup_allowlist_policies()
                    self.pending_allowlist_reconcile = False

            self._flush_allowlist_if_needed()

            if self.pending_allowlist_reconcile:
                try:
                    self._reconcile_allowlist_policies()
                except Exception as e:
                    print(f"allowlist reconcile failed err={e}", flush=True)
                    self.pending_allowlist_reconcile = False

            if self.pending_rule_apply:
                for rn in list(self.pending_rule_apply):
                    rule = next((x for x in self.cfg.rules if x.name == rn), None)
                    try:
                        if rule:
                            self.apply_rule(rule, force=True)
                    except Exception as e:
                        print(f"apply failed name={rn} err={e}", flush=True)
                    finally:
                        self.pending_rule_apply.discard(rn)

            if p.poll() is not None:
                rc = p.returncode
                err_tail = ""
                try:
                    if p.stderr:
                        err_tail = p.stderr.read()[-2000:]
                except Exception:
                    pass
                print(f"event stream exited rc={rc} err_tail={err_tail!r}", flush=True)
                time.sleep(1)
                p = start_event_stream(self.cfg)
                continue

            if p.stdout is None:
                time.sleep(0.2)
                continue

            rlist, _, _ = select.select([p.stdout], [], [], 0.5)
            if not rlist:
                continue

            line = p.stdout.readline()
            if not line:
                continue
            line = line.strip()
            if not line:
                continue

            try:
                ev = json.loads(line)
            except Exception:
                continue

            if self.cfg.allowlist:
                self._handle_process_connect_for_allowlist(ev)
                self._handle_process_dns_for_allowlist(ev)

        try:
            p.terminate()
        except Exception:
            pass


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--config", required=True)
    args = ap.parse_args()
    tb = TetraBlocker(args.config)
    tb.run()

if __name__ == "__main__":
    main()




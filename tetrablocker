@dataclass
class Rule:
    name: str
    binary: str
    domains: List[str]
    action: str = "Sigkill"
    protocol: str = "tcp"
    ports: List[int] = field(default_factory=list)
    ip_ttl_seconds: int = 900
    max_ips: int = 256
    apply_cooldown_seconds: int = 1

    def norm_domains(self) -> List[str]:
        return sorted({norm_domain(x) for x in self.domains if norm_domain(x)})

    def spec_hash(self) -> str:
        obj = {
            "name": self.name,
            "binary": self.binary,
            "domains": self.norm_domains(),
            "action": self.action,
            "protocol": self.protocol,
            "ports": sorted([int(x) for x in self.ports]),
            "ip_ttl_seconds": int(self.ip_ttl_seconds),
            "max_ips": int(self.max_ips),
            "apply_cooldown_seconds": int(self.apply_cooldown_seconds),
        }
        return sha256_json(obj)

@dataclass
class RuleState:
    name: str
    spec_hash: str = ""
    last_apply_ts: float = 0.0
    last_yaml_hash: str = ""
    ip_cache: Dict[str, float] = field(default_factory=dict)



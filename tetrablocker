@dataclass
class ALItem:
    binary: str
    binary_operator: str
    proto: str               # "tcp" or "udp"
    port: int                # single port per item (learning produces per-port items)
    domains: List[str] = field(default_factory=list)  # normalized domains
    cidrs: List[str] = field(default_factory=list)    # /32 or /128 or cidr
    updated_at: float = 0.0

    def key(self) -> Tuple[str, str, str, int]:
        return (self.binary_operator, self.binary, self.proto, self.port)

def bin_pattern_to_operator(binary: str) -> Tuple[str, str]:
    b = (binary or "").strip()
    if b.endswith("/*"):
        return ("Prefix", b[:-1])  # keep trailing "/"
    if b.startswith("*"):
        return ("Postfix", b[1:])
    return ("In", b)

def compress_ports_to_values(ports: List[int], max_values: int = 4) -> List[str]:
    ps = sorted(set([int(x) for x in ports if int(x) > 0 and int(x) <= 65535]))
    if not ps:
        return []
    # Compress contiguous ranges to "min:max"
    ranges: List[Tuple[int, int]] = []
    s = ps[0]
    e = ps[0]
    for p in ps[1:]:
        if p == e + 1:
            e = p
        else:
            ranges.append((s, e))
            s = p
            e = p
    ranges.append((s, e))
    vals: List[str] = []
    for a, b in ranges:
        vals.append(str(a) if a == b else f"{a}:{b}")
    # If still too many, keep first max_values
    return vals[:max_values]

def chunk_list(xs: List[str], n: int) -> List[List[str]]:
    out: List[List[str]] = []
    cur: List[str] = []
    for x in xs:
        cur.append(x)
        if len(cur) >= n:
            out.append(cur)
            cur = []
    if cur:
        out.append(cur)
    return out


def render_single_rule_yaml(rule: Rule, cidrs: List[str]) -> str:
    cidrs_sorted = sorted({c.strip() for c in cidrs if c and c.strip()})
    port_vals = [str(int(p)) for p in rule.ports]
    lines: List[str] = []
    lines.append("apiVersion: cilium.io/v1alpha1")
    lines.append("kind: TracingPolicy")
    lines.append("metadata:")
    lines.append(f"  name: {rule.name}")
    lines.append("spec:")
    lines.append("  kprobes:")
    lines.append("  - call: tcp_connect")
    lines.append("    syscall: false")
    lines.append("    args:")
    lines.append("    - index: 0")
    lines.append("      type: sock")
    lines.append("    selectors:")
    lines.append("    - matchBinaries:")
    lines.append("      - operator: In")
    lines.append("        values:")
    lines.append(f"        - \"{rule.binary}\"")
    lines.append("      matchArgs:")
    lines.append("      - index: 0")
    lines.append("        operator: DAddr")
    lines.append("        values:")
    for c in cidrs_sorted:
        lines.append(f"        - \"{c}\"")
    if port_vals:
        lines.append("      - index: 0")
        lines.append("        operator: DPort")
        lines.append("        values:")
        for p in port_vals:
            lines.append(f"        - \"{p}\"")
    lines.append("      matchActions:")
    lines.append(f"      - action: {rule.action}")
    lines.append("")
    return "\n".join(lines)

def render_allowlist_policy_yaml(
    name: str,
    call: str,
    bin_operator: str,
    bin_value: str,
    allow_selectors: List[Tuple[List[str], List[List[str]]]],
    deny_action: Optional[str],
) -> str:
    lines: List[str] = []
    lines.append("apiVersion: cilium.io/v1alpha1")
    lines.append("kind: TracingPolicy")
    lines.append("metadata:")
    lines.append(f"  name: {name}")
    lines.append("spec:")
    lines.append("  kprobes:")
    lines.append(f"  - call: {call}")
    lines.append("    syscall: false")
    lines.append("    args:")
    lines.append("    - index: 0")
    lines.append("      type: sock")
    lines.append("    selectors:")

    for port_vals, addr_chunks in allow_selectors:
        if not addr_chunks:
            lines.append("    - matchBinaries:")
            lines.append(f"      - operator: {bin_operator}")
            lines.append("        values:")
            lines.append(f"        - \"{bin_value}\"")
            if port_vals:
                lines.append("      matchArgs:")
                lines.append("      - index: 0")
                lines.append("        operator: DPort")
                lines.append("        values:")
                for pv in port_vals:
                    lines.append(f"        - \"{pv}\"")
            lines.append("      matchActions:")
            lines.append("      - action: NoPost")
            continue

        for addr_vals in addr_chunks:
            lines.append("    - matchBinaries:")
            lines.append(f"      - operator: {bin_operator}")
            lines.append("        values:")
            lines.append(f"        - \"{bin_value}\"")
            lines.append("      matchArgs:")
            if port_vals:
                lines.append("      - index: 0")
                lines.append("        operator: DPort")
                lines.append("        values:")
                for pv in port_vals:
                    lines.append(f"        - \"{pv}\"")
            lines.append("      - index: 0")
            lines.append("        operator: DAddr")
            lines.append("        values:")
            for av in addr_vals:
                lines.append(f"        - \"{av}\"")
            lines.append("      matchActions:")
            lines.append("      - action: NoPost")

    if deny_action:
        lines.append("    - matchBinaries:")
        lines.append(f"      - operator: {bin_operator}")
        lines.append("        values:")
        lines.append(f"        - \"{bin_value}\"")
        lines.append("      matchActions:")
        lines.append(f"      - action: {deny_action}")

    lines.append("")
    return "\n".join(lines)

def render_unknown_policy_yaml(
    name: str,
    call: str,
    match_blocks: List[Tuple[str, List[str]]],
    deny_action: str,
    allow_dns_stub: bool,
    dns_stub_cidrs: List[str],
    dns_stub_ports: List[int],
) -> str:
    lines: List[str] = []
    lines.append("apiVersion: cilium.io/v1alpha1")
    lines.append("kind: TracingPolicy")
    lines.append("metadata:")
    lines.append(f"  name: {name}")
    lines.append("spec:")
    lines.append("  kprobes:")
    lines.append(f"  - call: {call}")
    lines.append("    syscall: false")
    lines.append("    args:")
    lines.append("    - index: 0")
    lines.append("      type: sock")
    lines.append("    selectors:")

    # Global allow: any process -> local DNS stub only
    if allow_dns_stub:
        cidrs = [c.strip() for c in (dns_stub_cidrs or []) if c.strip()]
        ports = sorted(set([int(p) for p in (dns_stub_ports or []) if int(p) > 0 and int(p) <= 65535]))
        if cidrs and ports:
            lines.append("    - matchBinaries:")
            lines.append("      - operator: Prefix")
            lines.append("        values:")
            lines.append("        - \"/\"")
            lines.append("      matchArgs:")
            lines.append("      - index: 0")
            lines.append("        operator: DPort")
            lines.append("        values:")
            for p in ports:
                lines.append(f"        - \"{p}\"")
            lines.append("      - index: 0")
            lines.append("        operator: DAddr")
            lines.append("        values:")
            for c in cidrs:
                lines.append(f"        - \"{c}\"")
            lines.append("      matchActions:")
            lines.append("      - action: NoPost")

    # Deny unknown binaries
    lines.append("    - matchBinaries:")
    for op, vals in match_blocks:
        if not vals:
            continue
        lines.append(f"      - operator: {op}")
        lines.append("        values:")
        for v in vals:
            lines.append(f"        - \"{v}\"")
    lines.append("      matchActions:")
    lines.append(f"      - action: {deny_action}")
    lines.append("")
    return "\n".join(lines)



def _ensure_executable(path_or_name: str) -> None:
    if os.path.isabs(path_or_name):
        if not os.path.exists(path_or_name) or not os.access(path_or_name, os.X_OK):
            raise RuntimeError(f"tetra_bin not executable: {path_or_name}")
    else:
        # best-effort: rely on PATH resolution by subprocess
        return

def tetra_delete_policy(cfg, name: str) -> None:
    candidates = [
        [cfg.tetra_bin] + cfg.tetra_args + ["tp", "delete", name],
        [cfg.tetra_bin] + cfg.tetra_args + ["tp", "del", name],
        [cfg.tetra_bin] + cfg.tetra_args + ["tracingpolicy", "delete", name],
        [cfg.tetra_bin] + cfg.tetra_args + ["tracingpolicy", "del", name],
        [cfg.tetra_bin] + cfg.tetra_args + ["tracingpolicy", "remove", name],
    ]
    for c in candidates:
        rc, _, _ = run_cmd(c, timeout=20)
        if rc == 0:
            return

def tetra_add_policy(cfg, yaml_path: str) -> None:
    candidates = [
        [cfg.tetra_bin] + cfg.tetra_args + ["tp", "add", yaml_path],
        [cfg.tetra_bin] + cfg.tetra_args + ["tracingpolicy", "add", yaml_path],
    ]
    last_err = ""
    for c in candidates:
        rc, _, err = run_cmd(c, timeout=60)
        if rc == 0:
            return
        last_err = err.strip()
    raise RuntimeError(f"policy add failed: {last_err}")

def tetra_list_policies(cfg) -> List[str]:
    cmd = [cfg.tetra_bin] + cfg.tetra_args + ["tracingpolicy", "list"]
    rc, out, _ = run_cmd(cmd, timeout=20)
    if rc != 0:
        return []
    names: List[str] = []
    for line in out.splitlines():
        line = line.strip()
        if not line or line.startswith("ID") or line.startswith("---"):
            continue
        parts = re.split(r"\s+", line)
        if len(parts) >= 2:
            names.append(parts[1])
    return names

def start_event_stream(cfg) -> subprocess.Popen:
    _ensure_executable(cfg.tetra_bin)
    cmd = [cfg.tetra_bin] + cfg.tetra_args + ["getevents", "--host"]
    return subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True, bufsize=1)

def dns_dump(cfg) -> str:
    _ensure_executable(cfg.tetra_bin)
    cmd1 = [cfg.tetra_bin] + cfg.tetra_args + ["debug", "dns", "dump"]
    rc, out, err = run_cmd(cmd1, timeout=30)
    if rc == 0 and out.strip():
        return out
    cmd2 = [cfg.tetra_bin] + cfg.tetra_args + ["debug", "dns"]
    rc, out, err = run_cmd(cmd2, timeout=30)
    if rc == 0 and out.strip():
        return out
    raise RuntimeError(f"dns dump failed rc={rc} err={err.strip()}")

def parse_dns_dump(text: str) -> List[Tuple[str, str]]:
    pairs: List[Tuple[str, str]] = []
    for line in text.splitlines():
        line = line.strip()
        if not line:
            continue
        if line.lower().startswith("ip"):
            continue
        parts = re.split(r"\s+", line)
        if len(parts) < 2:
            continue
        ip = parts[0].strip()
        dom = norm_domain(parts[1].strip())
        if valid_ip(ip) and dom:
            pairs.append((ip, dom))
    return pairs

def prewarm_domain(domain: str) -> None:
    d = domain[:-1] if domain.endswith(".") else domain
    if not d:
        return
    run_cmd(["/usr/bin/getent", "ahosts", d], timeout=10)



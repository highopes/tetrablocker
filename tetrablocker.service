[Unit]
Description=TetraBlocker - dynamic TracingPolicy generator from DNS events
After=network-online.target systemd-resolved.service tetragon-enterprise.service
Wants=network-online.target tetragon-enterprise.service

[Service]
Type=simple
User=root
Group=root
Environment=PYTHONUNBUFFERED=1
ExecStart=/usr/bin/python3 /usr/local/bin/tetrablocker --config /etc/tetrablocker/tetrablocker.conf
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
